# Neo4j (user fills in via UI; these are defaults for dev)
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# LLM API keys (optional defaults; user enters via UI sidebar)
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=
ANTHROPIC_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000

# Upload
MAX_UPLOAD_MB=50
UPLOAD_DIR=./uploads
